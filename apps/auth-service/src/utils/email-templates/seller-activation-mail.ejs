<!DOCTYPE html>
<html>

<head>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
        }

        .email-wrapper {
            max-width: 600px;
            margin: 40px auto;
            background-color: #ffffff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .email-header {
            background-color: #3489FF;
            padding: 24px;
            text-align: center;
        }

        .email-header h1 {
            color: #ffffff;
            margin: 0;
            font-size: 24px;
        }

        .email-body {
            padding: 32px;
            color: #333333;
        }

        .email-body h2 {
            font-size: 36px;
            letter-spacing: 8px;
            text-align: center;
            color: #3489FF;
            margin: 24px 0;
        }

        .email-body p {
            font-size: 15px;
            line-height: 1.6;
            color: #555555;
        }

        .email-footer {
            background-color: #f4f4f4;
            padding: 20px 32px;
            text-align: center;
            font-size: 13px;
            color: #999999;
        }

        .email-footer a {
            color: #3489FF;
            text-decoration: none;
        }
    </style>
</head>

<body>
    <div class="email-wrapper">
        <div class="email-header">
            <h1>Welcome to Eshop</h1>
        </div>
        <div class="email-body">
            <p>Hello <%= name %>,</p>
            <p>
                Thank you for registering with Eshop. To activate your seller account,
                please use the following activation code:
            </p>
            <h2>
                <%= otp %>
            </h2>
            <p>
                Please enter this code on the activation page within the next 5
                minutes.
            </p>
            <p>
                If you did not register for a Eshop seller account, please ignore this
                email.
            </p>
        </div>
        <div class="email-footer">
            <p>
                If you have any questions, please don't hesitate to contact us at
                <a href="mailto:support@becodemy.com">support@becodemy.com</a>
            </p>
        </div>
    </div>
</body>

</html>