<!DOCTYPE html>
<html>

<head>
    <title>Eshop Activation Email</title>

    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <style type="text/css">
        /* Base */
        body {
            margin: 0;
            padding: 0;
            min-width: 100%;
            font-family: Arial, sans-serif;
            font-size: 16px;
            line-height: 1.5;
            background-color: #fafafa;
            color: #222222;
        }

        a {
            color: #000;
            text-decoration: none;
        }

        h1 {
            font-size: 24px;
            font-weight: 700;
            line-height: 1.25;
            margin-top: 0;
            margin-bottom: 15px;
            text-align: center;
        }

        h2 {
            font-size: 22px;
            font-weight: 700;
            margin: 20px 0;
            text-align: center;
            color: #0070f3;
        }

        p {
            margin-top: 0;
            margin-bottom: 24px;
            text-align: center;
        }

        /* Layout */
        .email-wrapper {
            max-width: 600px;
            margin: 0 auto;
        }

        .email-header {
            background-color: #0070f3;
            padding: 24px;
            color: #ffffff;
            text-align: center;
        }

        .email-body {
            padding: 24px;
            background-color: #ffffff;
        }

        .email-footer {
            background-color: #f6f6f6;
            padding: 24px;
            text-align: center;
            font-size: 14px;
        }

        /* Button */
        .button {
            display: inline-block;
            background-color: #0070f3;
            color: #ffffff !important;
            padding: 12px 24px;
            border-radius: 5px;
            font-size: 14px;
            font-weight: 600;
            text-align: center;
        }
    </style>
</head>

<body>
    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td>
                <table class="email-wrapper" width="100%" cellpadding="0" cellspacing="0">

                    <!-- Header -->
                    <tr>
                        <td class="email-header">
                            <h1>Welcome to Eshop</h1>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td class="email-body">

                            <h1>Activate Your Account</h1>

                            <p>Hello <%= name %>,</p>

                            <p>
                                Thank you for registering with us. Please use the activation code below to activate your
                                account.
                            </p>

                            <!-- OTP Code -->
                            <h2>
                                <%= otp %>
                            </h2>

                            <p>
                                Please enter this code on the activation page within the next 5 minutes.
                            </p>

                            <p>
                                If you did not register for an Eshop account, please ignore this email.
                            </p>

                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td class="email-footer">
                            <p>
                                If you have any questions, please don't hesitate to contact us at
                            </p>

                            <p>
                                <a href="mailto:support@becodemy.com">
                                    support@becodemy.com
                                </a>
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>

</html>